import streamlit as st
import yfinance as yf
import pandas as pd
import plotly.graph_objects as go
from plotly.subplots import make_subplots
from datetime import datetime, timedelta

st.set_page_config(page_title="Momentum Trading Setup", layout="wide")
st.title("SROP-Style Momentum Dashboard")

SECTORS = {
    "Nifty IT": "^CNXIT",
    "Nifty Auto": "^CNXAUTO",
    "Nifty Bank": "^NSEBANK",
    "Nifty FMCG": "^CNXFMCG",
    "Nifty Metal": "^CNXMETAL",
    "Nifty Pharma": "^CNXPHARMA",
    "Nifty Energy": "^CNXENERGY"
}

SECTOR_STOCKS = {
    "Nifty IT": ["TCS.NS", "INFY.NS", "WIPRO.NS", "HCLTECH.NS"],
    "Nifty Auto": ["TATAMOTORS.NS", "M&M.NS", "MARUTI.NS", "BAJAJ-AUTO.NS"],
    "Nifty Bank": ["HDFCBANK.NS", "ICICIBANK.NS", "SBIN.NS", "AXISBANK.NS"],
    "Nifty FMCG": ["ITC.NS", "HUL.NS", "NESTLEIND.NS", "DABUR.NS"],
    "Nifty Metal": ["TATASTEEL.NS", "HINDALCO.NS", "JSWSTEEL.NS", "VEDL.NS"],
    "Nifty Pharma": ["SUNPHARMA.NS", "CIPLA.NS", "DRREDDY.NS", "DIVISLAB.NS"],
    "Nifty Energy": ["RELIANCE.NS", "ONGC.NS", "NTPC.NS", "POWERGRID.NS"]
}

st.sidebar.header("Dashboard Controls")
lookback_days = st.sidebar.slider("Lookback Period (Days)", 5, 60, 30)

end_date = datetime.today()
start_date = end_date - timedelta(days=lookback_days)

st.header("1. Sectorial Grid (Relative Strength)")

@st.cache_data(ttl=300)
def get_sector_performance():
    perf_data = {}
    for name, ticker in SECTORS.items():
        try:
            df = yf.download(ticker, start=start_date, end=end_date, progress=False)
            if not df.empty:
                start_price = df['Close'].iloc[0].item()
                end_price = df['Close'].iloc[-1].item()
                pct_change = ((end_price - start_price) / start_price) * 100
                perf_data[name] = pct_change
        except:
            pass
    return pd.DataFrame(list(perf_data.items()), columns=['Sector', '% Change']).sort_values(by='% Change', ascending=True)

sector_df = get_sector_performance()

fig_sectors = go.Figure(go.Bar(
    x=sector_df['% Change'],
    y=sector_df['Sector'],
    orientation='h',
    marker_color=['red' if x < 0 else 'green' for x in sector_df['% Change']]
))
fig_sectors.update_layout(title="Sector Performance", height=400)
st.plotly_chart(fig_sectors, use_container_width=True)

st.header("2. Stock Picker & Volume/VWAP Analysis")
col1, col2 = st.columns([1, 3])

with col1:
    selected_sector = st.selectbox("Select Sector:", list(SECTORS.keys()))
    stock_list = SECTOR_STOCKS[selected_sector]
    selected_stock = st.radio("Select Stock:", stock_list)

with col2:
    if selected_stock:
        df = yf.download(selected_stock, period="5d", interval="15m", progress=False)
        
        if not df.empty:
            if isinstance(df.columns, pd.MultiIndex):
                df.columns = df.columns.get_level_values(0)

            df['Typical_Price'] = (df['High'] + df['Low'] + df['Close']) / 3
            df['VWAP'] = (df['Typical_Price'] * df['Volume']).cumsum() / df['Volume'].cumsum()
            df['Vol_MA'] = df['Volume'].rolling(window=10).mean()

            fig = make_subplots(rows=2, cols=1, shared_xaxes=True, 
                                vertical_spacing=0.03, row_heights=[0.7, 0.3])

            fig.add_trace(go.Candlestick(x=df.index, open=df['Open'], high=df['High'], 
                                         low=df['Low'], close=df['Close'], name='Price'), 
                          row=1, col=1)
            
            fig.add_trace(go.Scatter(x=df.index, y=df['VWAP'], line=dict(color='orange', width=2), name='VWAP'), 
                          row=1, col=1)

            colors = ['green' if close >= open else 'red' for close, open in zip(df['Close'], df['Open'])]
            fig.add_trace(go.Bar(x=df.index, y=df['Volume'], marker_color=colors, name='Volume'), 
                          row=2, col=1)
            
            fig.add_trace(go.Scatter(x=df.index, y=df['Vol_MA'], line=dict(color='blue', width=1.5), name='Vol MA'), 
                          row=2, col=1)

            fig.update_layout(title="15m Chart with VWAP & Volume Breakout", 
                              xaxis_rangeslider_visible=False, height=600)
            st.plotly_chart(fig, use_container_width=True)
